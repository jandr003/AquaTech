<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    app:cardCornerRadius="24dp"
    app:cardElevation="8dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- AquaTech Logo Header -->
        <ImageView
            android:id="@+id/ivLogoHeader"
            android:layout_width="120dp"
            android:layout_height="60dp"
            android:src="@drawable/asc_logooo"
            android:scaleType="fitCenter"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/poppins_black_ttf"
            android:text="Response Language"
            android:textColor="@color/aqua_text_dark"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivLogoHeader" />

        <TextView
            android:id="@+id/tvDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/poppins"
            android:text="Select how AquaBuddy speaks to you"
            android:textColor="#757575"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTitle" />

        <!-- Language Selection Group -->
        <RadioGroup
            android:id="@+id/rgLanguages"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/tvDesc">

            <RadioButton
                android:id="@+id/rbTagalog"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:fontFamily="@font/poppins"
                android:text="Tagalog"
                android:textColor="#444444"
                android:buttonTint="@color/aqua_primary"
                android:textSize="15sp" />

            <RadioButton
                android:id="@+id/rbTaglish"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:fontFamily="@font/poppins"
                android:text="Taglish"
                android:textColor="#444444"
                android:buttonTint="@color/aqua_primary"
                android:textSize="15sp" />

            <RadioButton
                android:id="@+id/rbEnglish"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:fontFamily="@font/poppins"
                android:text="English"
                android:textColor="#444444"
                android:buttonTint="@color/aqua_primary"
                android:textSize="15sp" />
        </RadioGroup>

        <Button
            android:id="@+id/btnSaveLanguage"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="@color/aqua_cicle"
            android:fontFamily="@font/poppins"
            android:text="Save Selection"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            app:cornerRadius="12dp"
            app:layout_constraintTop_toBottomOf="@id/rgLanguages" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
