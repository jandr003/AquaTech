<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <!-- 1. HEADER SECTION -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/header_gradient"
        app:elevation="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="18dp"
            android:paddingTop="40dp"
            android:paddingBottom="16dp">

            <ImageView
                android:id="@+id/btnBackAnalytics"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/arrow_back"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="#FFFFFF" />

            <TextView
                android:id="@+id/tvHeaderTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:fontFamily="@font/poppins_black_ttf"
                android:text="MONTHLY AUDIT"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/btnBackAnalytics"
                app:layout_constraintStart_toEndOf="@id/btnBackAnalytics"
                app:layout_constraintTop_toTopOf="@id/btnBackAnalytics" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnExportMonthlyPdf"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EXPORT PDF"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                app:icon="@drawable/ic_download"
                app:iconTint="#FFFFFF"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="32dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- CORE KPIs -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#1E3A8A"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Service Request Efficiency"
                        android:textColor="#93C5FD"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp">
                        <TextView
                            android:id="@+id/tvCompletionRate"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textColor="#FFFFFF"
                            android:textSize="32sp"
                            android:fontFamily="@font/poppins_black_ttf" />

                        <TextView
                            android:id="@+id/tvRateTrend"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toEndOf="@id/tvCompletionRate"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="12dp"
                            android:text="Stable"
                            android:textColor="#8BC34A"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#40FFFFFF"
                        android:layout_marginVertical="16dp"/>

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="2">

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical" android:layout_marginBottom="12dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Avg. Response" android:textColor="#93C5FD" android:textSize="10sp"/>
                            <TextView android:id="@+id/tvAvgResponse" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 Mins" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="14sp"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Resolution Time" android:textColor="#93C5FD" android:textSize="10sp"/>
                            <TextView android:id="@+id/tvResolutionTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0 Mins" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="14sp"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Total Requests" android:textColor="#93C5FD" android:textSize="10sp"/>
                            <TextView android:id="@+id/tvTotalMonthlyJobsSnapshot" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="14sp"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_columnWeight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CSAT Score" android:textColor="#93C5FD" android:textSize="10sp"/>
                            <TextView android:id="@+id/tvCsatScore" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⭐ 0.0" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="14sp"/>
                        </LinearLayout>
                    </GridLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- GROWTH TRENDS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginStart="4dp"
                android:text="WEEKLY GROWTH TRENDS"
                android:fontFamily="@font/poppins_black_ttf"
                android:textColor="#333333"
                android:textSize="14sp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="bottom"
                    android:orientation="horizontal"
                    android:padding="24dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center_horizontal|bottom" android:orientation="vertical">
                        <com.google.android.material.card.MaterialCardView android:id="@+id/barW1" android:layout_width="45dp" android:layout_height="10dp" app:cardBackgroundColor="#1E3A8A" app:cardCornerRadius="6dp" app:cardElevation="0dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="W1" android:textSize="9sp" android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center_horizontal|bottom" android:orientation="vertical">
                        <com.google.android.material.card.MaterialCardView android:id="@+id/barW2" android:layout_width="45dp" android:layout_height="10dp" app:cardBackgroundColor="#1E3A8A" app:cardCornerRadius="6dp" app:cardElevation="0dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="W2" android:textSize="9sp" android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center_horizontal|bottom" android:orientation="vertical">
                        <com.google.android.material.card.MaterialCardView android:id="@+id/barW3" android:layout_width="45dp" android:layout_height="10dp" app:cardBackgroundColor="#1E3A8A" app:cardCornerRadius="6dp" app:cardElevation="0dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="W3" android:textSize="9sp" android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center_horizontal|bottom" android:orientation="vertical">
                        <com.google.android.material.card.MaterialCardView android:id="@+id/barW4" android:layout_width="45dp" android:layout_height="10dp" app:cardBackgroundColor="#1E3A8A" app:cardCornerRadius="6dp" app:cardElevation="0dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="W4" android:textSize="9sp" android:layout_marginTop="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- CUSTOM SEARCH ROW -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:paddingHorizontal="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/poppins_black_ttf"
                    android:text="MONTHLY REQUESTS LOG"
                    android:textColor="#333333"
                    android:textSize="13sp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="160dp"
                    android:layout_height="36dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#CCCCCC"
                    app:strokeWidth="1.5dp">

                    <androidx.appcompat.widget.SearchView
                        android:id="@+id/searchAuditLog"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layoutDirection="rtl"
                        app:iconifiedByDefault="false"
                        app:queryHint="Search..."
                        app:searchIcon="@android:drawable/ic_menu_search"
                        app:queryBackground="@android:color/transparent"
                        app:submitBackground="@android:color/transparent" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- LOG LIST CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="14dp"
                        android:paddingHorizontal="16dp"
                        android:orientation="horizontal"
                        android:background="#FAFAFA">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.3" android:text="TICKET" android:textSize="10sp" android:textStyle="bold" android:textColor="#1E3A8A" android:fontFamily="@font/poppins"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="CUSTOMER" android:textSize="10sp" android:textStyle="bold" android:textColor="#1E3A8A" android:fontFamily="@font/poppins"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:minWidth="70dp" android:gravity="end" android:text="STATUS" android:textSize="10sp" android:textStyle="bold" android:textColor="#1E3A8A" android:fontFamily="@font/poppins"/>
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvMonthlyDetailedLog"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingBottom="12dp"
                        android:nestedScrollingEnabled="false"
                        tools:listitem="@layout/item_audit_log" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
