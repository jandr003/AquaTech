<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/white"
    android:orientation="vertical"
    android:padding="40dp">

    <!-- Logo Section -->
    <ImageView
        android:layout_width="240dp"
        android:layout_height="90dp"
        android:layout_gravity="center_horizontal"
        android:src="@drawable/asc_logo_all_about_water"
        android:scaleType="fitCenter" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:fontFamily="@font/poppins_black_ttf"
        android:text="Receipt Summary"
        android:textStyle="bold"
        android:textColor="#AAAAAA"
        android:textSize="14sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="25dp"
        android:background="#EEEEEE" />

    <!-- Customer Information -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins"
        android:text="CUSTOMER INFORMATION"
        android:textColor="#AAAAAA"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/pdfCustomerName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:fontFamily="@font/poppins_black_ttf"
        android:text="Name"
        android:textColor="#333333"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/pdfAddress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:fontFamily="@font/poppins"
        android:text="Address"
        android:textColor="#777777"
        android:textSize="15sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="25dp"
        android:background="#EEEEEE" />

    <!-- Service Details -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins"
        android:text="SERVICE DETAILS"
        android:textColor="#AAAAAA"
        android:textSize="12sp"
        android:textStyle="bold" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins"
            android:text="Ticket ID:"
            android:textColor="#999999"
            android:textSize="15sp" />
        <TextView
            android:id="@+id/pdfTicketId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:fontFamily="@font/poppins_black_ttf"
            android:text="#ASC2026-0000"
            android:textColor="#1C4E75"
            android:textSize="15sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins"
            android:text="Service Type:"
            android:textColor="#999999"
            android:textSize="15sp" />
        <TextView
            android:id="@+id/pdfServiceType"
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:fontFamily="@font/poppins"
            android:gravity="end"
            android:text="Service Type"
            android:textColor="#333333"
            android:textSize="15sp" />
    </RelativeLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins"
            android:text="Preferred Schedule:"
            android:textColor="#999999"
            android:textSize="15sp" />
        <TextView
            android:id="@+id/pdfSchedule"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:fontFamily="@font/poppins"
            android:text="Schedule"
            android:textColor="#333333"
            android:textSize="15sp" />
    </RelativeLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins"
            android:text="Request Date:"
            android:textColor="#999999"
            android:textSize="15sp" />
        <TextView
            android:id="@+id/pdfDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:fontFamily="@font/poppins"
            android:text="Date"
            android:textColor="#333333"
            android:textSize="15sp" />
    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="25dp"
        android:background="#EEEEEE" />

    <!-- Unit Information -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins"
        android:text="UNIT INFORMATION"
        android:textColor="#AAAAAA"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/pdfUnit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:fontFamily="@font/poppins"
        android:text="Unit Name"
        android:textColor="#333333"
        android:textSize="15sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="25dp"
        android:background="#EEEEEE" />

    <!-- Valid ID Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins"
        android:text="CUSTOMER VALID ID"
        android:textColor="#AAAAAA"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/pdfValidID"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:fontFamily="@font/poppins"
        android:text="NOT PROVIDED"
        android:textColor="#333333"
        android:textSize="15sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="25dp"
        android:background="#EEEEEE" />

    <!-- Remarks Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins"
        android:text="REMARKS"
        android:textColor="#AAAAAA"
        android:textSize="12sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/pdfRemarks"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:fontFamily="@font/poppins"
        android:text="N/A"
        android:textColor="#333333"
        android:textSize="15sp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="25dp"
        android:background="#EEEEEE" />

    <!-- Billing Summary -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins"
        android:text="BILLING SUMMARY"
        android:textColor="#AAAAAA"
        android:textSize="12sp"
        android:textStyle="bold" />

    <LinearLayout
        android:id="@+id/pdfOrdersContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="20dp"
        android:background="#EEEEEE" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_black_ttf"
            android:text="TOTAL AMOUNT"
            android:textColor="#333333"
            android:textSize="18sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/pdfTotalAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:fontFamily="@font/poppins_black_ttf"
            android:text="₱ 0.00"
            android:textColor="#1C4E75"
            android:textSize="20sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="35dp"
        android:background="#EEEEEE" />

    <!-- Status Section -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins"
            android:text="CURRENT STATUS"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/pdfStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:background="@drawable/status_open_blue"
            android:fontFamily="@font/poppins"
            android:paddingHorizontal="20dp"
            android:paddingVertical="6dp"
            android:text="OPEN"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Footer -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        android:fontFamily="@font/poppins"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:text="By viewing this receipt, you agree to our\nTerms of Use and Privacy Policy."
        android:textColor="#AAAAAA"
        android:textSize="12sp" />

</LinearLayout>
