<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout_admin"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- HEADER SECTION -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/adminHeader"
            android:layout_width="match_parent"
            android:layout_height="122dp"
            android:background="#1E3A8A"
            android:elevation="8dp"
            android:paddingHorizontal="18dp"
            android:paddingTop="40dp"
            android:paddingBottom="16dp"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/adminAvatar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="2dp"
                android:src="@drawable/admin_icon"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:shapeAppearanceOverlay="@style/CircleImage"
                app:strokeColor="#40FFFFFF"
                app:strokeWidth="1dp" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/aquatechLogo"
                android:layout_width="111dp"
                android:layout_height="111dp"
                android:layout_marginBottom="-8dp"
                android:layout_marginStart="-8dp"
                android:src="@drawable/all_about_water___2__2"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.688"
                app:shapeAppearanceOverlay="@style/CircleImage" />

            <TextView
                android:id="@+id/tvWelcomeBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins"
                android:includeFontPadding="false"
                android:text="WELCOME BACK!"
                android:textColor="#93C5FD"
                android:textSize="11sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.183"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.245"
                app:layout_constraintVertical_chainStyle="packed" />

            <TextView
                android:id="@+id/tvAdminName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_black_ttf"
                android:includeFontPadding="false"
                android:text="John Andrew"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.228"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvWelcomeBack"
                app:layout_constraintVertical_bias="0.071" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/adminHeader">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingBottom="24dp">

                <!-- MAIN STATISTICS GRID -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="#F0F0F0"
                    app:cardCornerRadius="32dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:alignmentMode="alignMargins"
                        android:columnCount="2"
                        android:padding="8dp">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardInProgress"
                            android:layout_width="0dp"
                            android:layout_height="160dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="8dp"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardBackgroundColor="#448AFF"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="4dp">

                            <androidx.constraintlayout.widget.ConstraintLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="16dp">

                                <TextView
                                    android:id="@+id/lblP"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/poppins"
                                    android:text="In Progress"
                                    android:textColor="#FFFFFF"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toTopOf="parent" />

                                <TextView
                                    android:id="@+id/tvInProgressCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/poppins_black_ttf"
                                    android:text="0"
                                    android:textColor="#FFFFFF"
                                    android:textSize="32sp"
                                    android:textStyle="bold"
                                    app:layout_constraintBottom_toBottomOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toTopOf="parent" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/poppins"
                                    android:text="Assigned to Tech"
                                    android:textColor="#CCFFFFFF"
                                    android:textSize="12sp"
                                    app:layout_constraintBottom_toBottomOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toBottomOf="@+id/tvInProgressCount" />
                            </androidx.constraintlayout.widget.ConstraintLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardCompleted"
                            android:layout_width="0dp"
                            android:layout_height="160dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="8dp"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardBackgroundColor="#8BC34A"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="4dp">

                            <androidx.constraintlayout.widget.ConstraintLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="16dp">

                                <TextView
                                    android:id="@+id/lblC"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/poppins"
                                    android:text="Completed"
                                    android:textColor="#FFFFFF"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toTopOf="parent" />

                                <TextView
                                    android:id="@+id/tvCompletedCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/poppins_black_ttf"
                                    android:text="0"
                                    android:textColor="#FFFFFF"
                                    android:textSize="32sp"
                                    android:textStyle="bold"
                                    app:layout_constraintBottom_toBottomOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toTopOf="parent" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/poppins"
                                    android:text="Finished Jobs"
                                    android:textColor="#CCFFFFFF"
                                    android:textSize="12sp"
                                    app:layout_constraintBottom_toBottomOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toBottomOf="@+id/tvCompletedCount" />
                            </androidx.constraintlayout.widget.ConstraintLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardSubmissions"
                            android:layout_width="0dp"
                            android:layout_height="160dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="8dp"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardBackgroundColor="#FFB300"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="4dp">

                            <androidx.constraintlayout.widget.ConstraintLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="16dp">

                                <TextView
                                    android:id="@+id/lblS"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/poppins"
                                    android:text="Submissions"
                                    android:textColor="#FFFFFF"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toTopOf="parent" />

                                <TextView
                                    android:id="@+id/tvSubmissionCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/poppins_black_ttf"
                                    android:text="0"
                                    android:textColor="#FFFFFF"
                                    android:textSize="32sp"
                                    android:textStyle="bold"
                                    app:layout_constraintBottom_toBottomOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toTopOf="parent" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/poppins"
                                    android:text="For Admin Review"
                                    android:textColor="#CCFFFFFF"
                                    android:textSize="12sp"
                                    app:layout_constraintBottom_toBottomOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toBottomOf="@+id/tvSubmissionCount" />
                            </androidx.constraintlayout.widget.ConstraintLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardOpen"
                            android:layout_width="0dp"
                            android:layout_height="160dp"
                            android:layout_columnWeight="1"
                            android:layout_margin="8dp"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardBackgroundColor="#FF5252"
                            app:cardCornerRadius="24dp"
                            app:cardElevation="4dp">

                            <androidx.constraintlayout.widget.ConstraintLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="16dp">

                                <TextView
                                    android:id="@+id/lblO"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/poppins"
                                    android:text="Open"
                                    android:textColor="#FFFFFF"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toTopOf="parent" />

                                <TextView
                                    android:id="@+id/tvUrgentBadge"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="#FFFFFF"
                                    android:fontFamily="@font/poppins"
                                    android:paddingHorizontal="6dp"
                                    android:paddingVertical="2dp"
                                    android:text="URGENT"
                                    android:textColor="#FF5252"
                                    android:textSize="8sp"
                                    android:textStyle="bold"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintTop_toTopOf="parent" />

                                <TextView
                                    android:id="@+id/tvOverdueCount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/poppins_black_ttf"
                                    android:text="0"
                                    android:textColor="#FFFFFF"
                                    android:textSize="32sp"
                                    android:textStyle="bold"
                                    app:layout_constraintBottom_toBottomOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toTopOf="parent" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/poppins"
                                    android:text="For Assignment"
                                    android:textColor="#CCFFFFFF"
                                    android:textSize="12sp"
                                    app:layout_constraintBottom_toBottomOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toBottomOf="@+id/tvOverdueCount" />
                            </androidx.constraintlayout.widget.ConstraintLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </GridLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- QUICK PANELS SECTION -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:layout_marginStart="8dp"
                    android:fontFamily="@font/poppins_black_ttf"
                    android:text="QUICK PANELS"
                    android:textColor="#333333"
                    android:textSize="14sp" />

                <!-- Button 1: Technician Performance (Toned Down Blue) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardActionTechPerf"
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:layout_marginTop="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#4B91C6"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="0dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="16dp">

                        <View
                            android:id="@+id/circleTech"
                            android:layout_width="45dp"
                            android:layout_height="45dp"
                            android:backgroundTint="#40FFFFFF"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:layout_width="66dp"
                            android:layout_height="66dp"
                            android:src="@drawable/manage_tech_icon"
                            app:layout_constraintBottom_toBottomOf="@id/circleTech"
                            app:layout_constraintEnd_toEndOf="@id/circleTech"
                            app:layout_constraintStart_toStartOf="@id/circleTech"
                            app:layout_constraintTop_toTopOf="@id/circleTech"
                            app:tint="#FFFFFF" />

                        <TextView
                            android:id="@+id/tvTitleTech"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:fontFamily="@font/poppins_black_ttf"
                            android:text="Technician Performance"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toTopOf="@+id/tvSubTech"
                            app:layout_constraintStart_toEndOf="@id/circleTech"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintVertical_chainStyle="packed" />

                        <TextView
                            android:id="@+id/tvSubTech"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:fontFamily="@font/poppins"
                            android:text="Track ratings and service history"
                            android:textColor="#CCFFFFFF"
                            android:textSize="11sp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toEndOf="@id/circleTech"
                            app:layout_constraintTop_toBottomOf="@id/tvTitleTech" />

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Button 2: Recent Activity (Toned Down Blue) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardActionLogs"
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:layout_marginTop="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#4B91C6"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="0dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="16dp">

                        <View
                            android:id="@+id/circleLogs"
                            android:layout_width="45dp"
                            android:layout_height="45dp"
                            android:backgroundTint="#40FFFFFF"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:src="@drawable/recent_activity_icon"
                            app:layout_constraintBottom_toBottomOf="@id/circleLogs"
                            app:layout_constraintEnd_toEndOf="@id/circleLogs"
                            app:layout_constraintStart_toStartOf="@id/circleLogs"
                            app:layout_constraintTop_toTopOf="@id/circleLogs"
                            app:tint="#FFFFFF" />

                        <TextView
                            android:id="@+id/tvTitleLogs"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:fontFamily="@font/poppins_black_ttf"
                            android:text="Recent Activity"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toTopOf="@+id/tvSubLogs"
                            app:layout_constraintStart_toEndOf="@id/circleLogs"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintVertical_chainStyle="packed" />

                        <TextView
                            android:id="@+id/tvSubLogs"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:fontFamily="@font/poppins"
                            android:text="Real-time updates on system processes"
                            android:textColor="#CCFFFFFF"
                            android:textSize="11sp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toEndOf="@id/circleLogs"
                            app:layout_constraintTop_toBottomOf="@id/tvTitleLogs" />

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Button 3: Manage Technicians (Toned Down Blue) -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardActionManageTechs"
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:layout_marginTop="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#4B91C6"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="0dp">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="16dp">

                        <View
                            android:id="@+id/circleManage"
                            android:layout_width="45dp"
                            android:layout_height="45dp"
                            android:backgroundTint="#40FFFFFF"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <ImageView
                            android:layout_width="64dp"
                            android:layout_height="65dp"
                            android:src="@drawable/manage_tech_icon_1"
                            app:layout_constraintBottom_toBottomOf="@id/circleManage"
                            app:layout_constraintEnd_toEndOf="@id/circleManage"
                            app:layout_constraintStart_toStartOf="@id/circleManage"
                            app:layout_constraintTop_toTopOf="@id/circleManage"
                            app:tint="#FFFFFF" />

                        <TextView
                            android:id="@+id/tvTitleManage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:fontFamily="@font/poppins_black_ttf"
                            android:text="Manage Technicians"
                            android:textColor="#FFFFFF"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toTopOf="@+id/tvSubManage"
                            app:layout_constraintStart_toEndOf="@id/circleManage"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintVertical_chainStyle="packed" />

                        <TextView
                            android:id="@+id/tvSubManage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:fontFamily="@font/poppins"
                            android:text="Add, review, or disable accounts"
                            android:textColor="#CCFFFFFF"
                            android:textSize="11sp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintStart_toEndOf="@id/circleManage"
                            app:layout_constraintTop_toBottomOf="@id/tvTitleManage" />

                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.drawerlayout.widget.DrawerLayout>
