<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="4dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#F0F0F0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:orientation="vertical">
            <TextView
                android:id="@+id/auditTicketID"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ASC2026-0031"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#1E3A8A"
                android:fontFamily="@font/poppins_black_ttf"/>
            <TextView
                android:id="@+id/auditUnitSRO"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SRO-00012060"
                android:textSize="10sp"
                android:textColor="#888888"
                android:fontFamily="@font/poppins"/>
        </LinearLayout>

        <!-- Updated Placeholder to ASC-C001 -->
        <TextView
            android:id="@+id/auditCustomerID"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ASC-C001"
            android:textSize="11sp"
            android:textColor="#333333"
            android:fontFamily="@font/poppins"/>

        <TextView
            android:id="@+id/auditStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RESOLVED"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textColor="#8BC34A"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:background="@drawable/status_circle_green"
            android:backgroundTint="#F1F8E9"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>