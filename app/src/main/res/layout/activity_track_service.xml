<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6FBFF">

    <!-- 1. HEADER -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerTrack"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_marginStart="16dp"
            android:padding="8dp"
            android:src="@drawable/arrow_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.533"
            app:tint="#333333" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_black_ttf"
            android:text="Track"
            android:textColor="#333333"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 2. OPEN STREET MAPS (FREE) -->
    <org.osmdroid.views.MapView
        android:id="@+id/map"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerTrack"
        app:layout_constraintVertical_bias="0.0" />

    <!-- 🔍 ZOOM CONTROLS (Overlaid on Map) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="120dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.cardview.widget.CardView
            android:id="@+id/btnZoomIn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardBackgroundColor="@color/aqua_primary"
            android:clickable="true"
            app:cardCornerRadius="10dp"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="+"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:gravity="center"
                android:textStyle="bold"/>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/btnZoomOut"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="10dp"
            app:cardBackgroundColor="@color/aqua_primary"
            android:clickable="true"
            app:cardCornerRadius="10dp"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="—"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:gravity="center"
                android:textStyle="bold"/>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- 3. TECHNICIAN INFO CARD -->
    <androidx.cardview.widget.CardView
        android:id="@+id/techInfoCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <ImageView
                android:id="@+id/technicianAvatar"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/new_technician"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvTechName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/poppins_black_ttf"
                android:text="Waiting for Technician..."
                android:textColor="#333333"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@id/technicianAvatar"
                app:layout_constraintTop_toTopOf="@id/technicianAvatar" />

            <TextView
                android:id="@+id/tvTechPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="---"
                android:textColor="#888888"
                app:layout_constraintStart_toStartOf="@id/tvTechName"
                app:layout_constraintTop_toBottomOf="@id/tvTechName" />

            <TextView
                android:id="@+id/tvEtaMins"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Calculating ETA..."
                android:textColor="#4B91C6"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="@id/tvTechName"
                app:layout_constraintTop_toBottomOf="@id/tvTechPhone" />

            <ImageView
                android:id="@+id/btnChat1"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/chat_1"
                app:tint="#DDDDDD"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btnCall1"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/btnCall1"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:rotation="0"
                app:tint="#DDDDDD"
                android:src="@android:drawable/ic_menu_call"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
