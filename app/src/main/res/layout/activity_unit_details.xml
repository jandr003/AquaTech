<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootConstraintLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <ImageView
        android:id="@+id/imageView3"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/aqua_background"
        android:scaleType="centerCrop" />


     <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/wave_curve_request" />

    <ImageView
        android:id="@+id/lessThanIcon"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:src="@drawable/arrow_back"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.043"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.051" />

    <TextView
        android:id="@+id/setUpAccount2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_black_ttf"
        android:text="SET UP YOUR ACCOUNT"
        android:textColor="#505050"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.061" />

    <TextView
        android:id="@+id/tvSetupSubtitle2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_black_ttf"
        android:text="ENTER YOUR APPLICANCES UNIT NO."
        android:textColor="#333333"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.099" />

    <androidx.cardview.widget.CardView
        android:id="@+id/whiteCardUnit01"
        android:layout_width="377dp"
        android:layout_height="520dp"
        app:cardBackgroundColor="#F8F8F8"
        app:cardCornerRadius="24dp"
        app:cardElevation="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.489"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.6">


        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp">


            <ImageView
                android:id="@+id/ascLogo"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:src="@drawable/asc_logooo"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/ItemOrder01"
                android:layout_width="150dp"
                android:layout_height="220dp"
                android:src="@drawable/titled_design1"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/ascLogo"
                app:layout_constraintVertical_bias="0.1" />


            <TextView
                android:id="@+id/itemWlCubeFirewall01"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:fontFamily="@font/poppins_black_ttf"
                android:gravity="start"
                android:text="COUNTER TOP WATER PURIFIER"
                android:textColor="#5B5B5B"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/ItemOrder01"
                app:layout_constraintTop_toTopOf="@+id/ItemOrder01" />

            <TextView
                android:id="@+id/ItemSubName01"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_black_ttf"
                android:gravity="start"
                android:text="F-FXCU1-M-HCA-TT-**-***"
                android:textColor="#5B5B5B"
                android:textSize="11sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@+id/itemWlCubeFirewall01"
                app:layout_constraintTop_toBottomOf="@+id/itemWlCubeFirewall01" />

            <!-- REFERENCE NUMBER FIELD -->
            <TextView
                android:id="@+id/tvReferenceNumberLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/poppins_black_ttf"
                android:text="REFERENCE NO."
                android:textColor="#5B5B5B"
                android:textSize="11sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="@+id/ItemSubName01"
                app:layout_constraintTop_toBottomOf="@+id/ItemSubName01" />

            <!-- UNIT NUMBER FIELD -->

            <EditText
                android:id="@+id/etReferenceNumber"
                android:layout_width="170dp"
                android:layout_height="42dp"
                android:background="@drawable/edittext_bg"
                android:hint="SRO-*******"
                android:padding="8dp"
                android:textColor="#000000"
                android:textSize="13sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="@+id/tvReferenceNumberLabel"
                app:layout_constraintTop_toBottomOf="@+id/tvReferenceNumberLabel" />

            <TextView
                android:id="@+id/itemUnitNumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/poppins_black_ttf"
                android:text="UNIT NO. (e.g. A1234)"
                android:textColor="#5B5B5B"
                android:textSize="10sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="@+id/etReferenceNumber"
                app:layout_constraintTop_toBottomOf="@+id/etReferenceNumber" />

            <!-- PURCHASE TYPE FIELD -->
            <EditText
                android:id="@+id/etUnitNumber"
                android:layout_width="170dp"
                android:layout_height="42dp"
                android:background="@drawable/edittext_bg"
                android:padding="8dp"
                android:textColor="#000000"
                android:textSize="13sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="@+id/itemUnitNumber"
                app:layout_constraintTop_toBottomOf="@+id/itemUnitNumber" />

            <TextView
                android:id="@+id/purchaseTypeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="@font/poppins_black_ttf"
                android:text="Type of Purchase"
                android:textColor="#5B5B5B"
                android:textSize="11sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="@+id/etUnitNumber"
                app:layout_constraintTop_toBottomOf="@+id/etUnitNumber" />

            <androidx.appcompat.widget.AppCompatSpinner
                android:id="@+id/purchaseTypeDropdown"
                android:layout_width="170dp"
                android:layout_height="35dp"
                android:background="@drawable/spinner_background"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="@+id/purchaseTypeLabel"
                app:layout_constraintTop_toBottomOf="@+id/purchaseTypeLabel" />

            <Button
                android:id="@+id/btnConfirm"
                android:layout_width="160dp"
                android:layout_height="55dp"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/poppins_black_ttf"
                android:text="Confirm"
                android:textSize="16sp"
                android:textStyle="bold"
                app:cornerRadius="20dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/purchaseTypeDropdown" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
