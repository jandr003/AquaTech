<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <View
        android:id="@+id/headerBg"
        android:layout_width="0dp"
        android:layout_height="240dp"
        android:background="@color/aqua_secondary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/ForgotHeader1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="48dp"
        android:fontFamily="@font/poppins_black_ttf"
        android:text="Confirm Your Password"
        android:textColor="@android:color/white"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/floatingCard"
        android:layout_width="360dp"
        android:layout_height="500dp"
        app:cardBackgroundColor="@android:color/white"
        app:cardCornerRadius="12dp"
        app:cardElevation="12dp"
        app:layout_constraintTop_toBottomOf="@id/ForgotHeader1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvForgotPassword"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_black_ttf"
                android:text="Set up your new password"
                android:textColor="#5F5F5F"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- New Password Input -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/poppins_black_ttf"
                android:text="Enter your new password"
                android:textColor="#4B91C6"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/yourNewPass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/edittext_bg"
                android:drawableEnd="@drawable/password_toggle_selector"
                android:fontFamily="@font/poppins_black_ttf"
                android:hint="Make it strong and secure"
                android:inputType="textPassword"
                android:padding="12dp"
                android:textColor="#000000"
                android:textColorHint="#33000000"
                android:textSize="16sp" />

            <!-- Length Warning -->
            <TextView
                android:id="@+id/yourNewPassWarning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Password should be 8–12 characters"
                android:textColor="#E53935"
                android:textSize="12sp"
                android:visibility="gone" />

            <!-- Confirm Password Input -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/poppins_black_ttf"
                android:text="Confirm your password"
                android:textColor="#4B91C6"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/reNewPass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/edittext_bg"
                android:drawableEnd="@drawable/password_toggle_selector"
                android:fontFamily="@font/poppins_black_ttf"
                android:hint="Type it again to confirm"
                android:inputType="textPassword"
                android:padding="12dp"
                android:textColor="#000000"
                android:textColorHint="#33000000"
                android:textSize="16sp" />

            <!-- Mismatch Warning -->
            <TextView
                android:id="@+id/reNewPassWarning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Oops! Your passwords don’t match"
                android:textColor="#E53935"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/poppins_black_ttf"
                android:text="Your Password:"
                android:textColor="#5F5F5F"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Requirements Indicators -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:paddingVertical="4dp">
                    <ImageView
                        android:id="@+id/IndicatorEight"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/circle_indicator" />
                    <TextView
                        android:id="@+id/eightPassword"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:fontFamily="@font/poppins_black_ttf"
                        android:text="Must have 8 or more characters"
                        android:textColor="#4B91C6"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:paddingVertical="4dp">
                    <ImageView
                        android:id="@+id/IndicatorLower"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/circle_indicator" />
                    <TextView
                        android:id="@+id/LowerPassword"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:fontFamily="@font/poppins_black_ttf"
                        android:text="Must have atleast 1 lowercase letter"
                        android:textColor="#4B91C6"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:paddingVertical="4dp">
                    <ImageView
                        android:id="@+id/IndicatorUpper"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/circle_indicator" />
                    <TextView
                        android:id="@+id/UpperPassword"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:fontFamily="@font/poppins_black_ttf"
                        android:text="Must have atleast 1 uppercase letter"
                        android:textColor="#4B91C6"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:paddingVertical="4dp">
                    <ImageView
                        android:id="@+id/IndicatorNumber"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/circle_indicator" />
                    <TextView
                        android:id="@+id/NumberPassword"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:fontFamily="@font/poppins_black_ttf"
                        android:text="Must have atleast 1 number"
                        android:textColor="#4B91C6"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:paddingVertical="4dp">
                    <ImageView
                        android:id="@+id/IndicatorSpecial"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/circle_indicator" />
                    <TextView
                        android:id="@+id/SpecialPassword"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:fontFamily="@font/poppins_black_ttf"
                        android:text="Must have atleast 1 special letter"
                        android:textColor="#4B91C6"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btnDonePassword"
        android:layout_width="102dp"
        android:layout_height="40dp"
        android:layout_marginEnd="5dp"
        android:layout_marginBottom="30dp"
        android:background="@drawable/button_bg"
        android:fontFamily="@font/poppins_black_ttf"
        android:foreground="?attr/selectableItemBackground"
        android:hapticFeedbackEnabled="true"
        android:soundEffectsEnabled="true"
        android:text="Done"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.934"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.758" />

</androidx.constraintlayout.widget.ConstraintLayout>