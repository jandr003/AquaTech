<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/fileContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/dialog_box_rounded"
        android:backgroundTint="#F0F4FF"
        android:elevation="0dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/upload_file_png" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvFileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="middle"
                android:fontFamily="@font/poppins_black_ttf"
                android:singleLine="true"
                android:text="Receipt.pdf"
                android:textColor="#2D5A9E"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvFileSize"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_black_ttf"
                android:text="1.2 MB"
                android:textColor="#7A869A"
                android:textSize="11sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/ivFileMenu"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:alpha="0.6"
            android:padding="4dp"
            android:src="@drawable/ic_chevron_down"
            android:rotation="270" />
    </LinearLayout>

</LinearLayout>
