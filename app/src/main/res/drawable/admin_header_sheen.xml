<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- The Base Gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#1E3A8A"
                android:endColor="#1E3A8A"
                android:angle="45"/>
        </shape>
    </item>
    <!-- The "Sheen" Overlay -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#1E3A8A"
                android:centerColor="#1E3A8A"
                android:endColor="#1E3A8A"
                android:angle="135"/>
        </shape>
    </item>
</layer-list>