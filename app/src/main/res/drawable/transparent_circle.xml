<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">

    <!-- Transparent fill -->
    <solid android:color="@android:color/transparent" />

    <!-- Border stroke with your color -->
    <stroke
        android:width="2dp"
        android:color="#4B91C6" />

    <!-- Size (optional, can be overridden by layout) -->
    <size
        android:width="48dp"
        android:height="48dp" />
</shape>